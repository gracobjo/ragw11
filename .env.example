# =============================================================================
# RAG Local - Configuración de ejemplo
# =============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo a .env:
#    - Windows: copy .env.example .env
#    - Ubuntu:  cp .env.example .env
# 2. Ajusta los valores según tu entorno.
# 3. No subas .env a git (contiene configuración local).
# =============================================================================

# --- Backend del LLM: ollama (por defecto), llamacpp o lmstudio ---
LLM_BACKEND=ollama

# --- Ollama (recomendado) ---
# Requiere Ollama instalado y en ejecución: https://ollama.com
# Para importar modelos GGUF de LM Studio: crea un Modelfile por modelo
# y ejecuta: ollama create nombre -f Modelfile
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=300

# --- Modo llamacpp (GGUF directo, sin Ollama) ---
# Descomenta y define la ruta al .gguf. Ejemplos:
#   Windows: GGUF_MODEL_PATH=C:\Users\tu_usuario\.lmstudio\models\...\modelo.gguf
#   Ubuntu:  GGUF_MODEL_PATH=/home/tu_usuario/.cache/lm-studio/models/.../modelo.gguf
# Instalación previa: pip install -r requirements-llamacpp.txt
# En Ubuntu con GPU: LLAMA_N_GPU_LAYERS=-1 (carga todas las capas en GPU)
# GGUF_MODEL_PATH=
# LLAMA_N_GPU_LAYERS=0
# LLAMA_N_CTX=4096
# LLAMA_MAX_TOKENS=512

# --- Modo LM Studio ---
# Requiere LM Studio con servidor en puerto 1234
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LM_STUDIO_MODEL=
# OPENAI_API_KEY=lm-studio

# --- Embeddings (Hugging Face) ---
# Modelo local para generar vectores. Primera ejecución descarga ~80MB.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Dispositivo: "cpu" (por defecto) o "cuda" (GPU NVIDIA). En Ubuntu con GPU:
# EMBEDDING_DEVICE=cuda
# Opcional: token para mayor velocidad y límites (https://huggingface.co/settings/tokens)
# HF_TOKEN=tu_token_aqui

# --- Hiperparámetros RAG ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVER_K=4
LLM_TEMPERATURE=0.2

# --- Agente ReAct ---
# AGENT_MAX_ITERATIONS=5
