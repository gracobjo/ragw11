# Copia este archivo a .env y ajusta valores.

# --- LLM: Ollama (por defecto), llamacpp o lmstudio ---
# LLM_BACKEND=ollama

# Ollama (API en localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_TIMEOUT=300

# Si LLM_BACKEND=llamacpp, ruta al .gguf:
# GGUF_MODEL_PATH=C:\Users\TU_USUARIO\.cache\lm-studio\models\...\modelo.gguf
#
# Instalación de llama-cpp-python (antes de usar llamacpp):
#   pip install -r requirements-llamacpp.txt
# (usa ruedas precompiladas; en Windows evita el error CMake/nmake).
# Alternativa: pip install llama-cpp-python --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu --prefer-binary

# Capas en GPU (-1 = todas si hay CUDA; 0 = solo CPU)
# LLAMA_N_GPU_LAYERS=0
# LLAMA_N_CTX=4096
# LLAMA_MAX_TOKENS=512

# URL del servidor OpenAI-compatible de LM Studio (incluye /v1)
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1

# Opcional: fija el id exacto del modelo cargado (LM Studio → pestaña del servidor)
# Ejemplo con Qwen VL:
# LM_STUDIO_MODEL=qwen/qwen3-vl-8b

# Clave ficticia (LM Studio no valida; algunas librerías la exigen)
OPENAI_API_KEY=lm-studio

# Embeddings locales (HuggingFace)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Hiperparámetros RAG
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
# RETRIEVER_K=4
# LLM_TEMPERATURE=0.2
